# surge-host 环境变量示例
# 复制后修改：cp .env.example .env
# 切勿将 .env 提交到 Git
#
# 生产参考：rules.asaqe.site（v2.4.1 最终版）

# ── Docker Compose / 1Panel 编排 ──
CONTAINER_NAME=surge-host
HOST_IP=
PANEL_APP_PORT_HTTP=28080

# ── 服务配置 ──
SURGE_HOST_DOMAIN=rules.example.com
SURGE_HOST_ADMIN_USER=admin
SURGE_HOST_ADMIN_PASSWORD=your-secure-password
SURGE_HOST_JWT_SECRET=your-random-secret-key

# 非回环域名（非 localhost / 127.0.0.1 / ::1）下，以上两项必须显式设置

# ── 可选配置 ──
# SURGE_HOST_MAX_FILE_SIZE=5242880
# SURGE_HOST_ALLOWED_EXTENSIONS=.conf,.list,.txt,.module,.yaml,.yml,.json
# SURGE_HOST_GIT_ENABLED=true
# SURGE_HOST_VALIDATE_ENABLED=true
# SURGE_HOST_VALIDATE_STRICT=false
# SURGE_HOST_CORS_ORIGINS=https://example.com
